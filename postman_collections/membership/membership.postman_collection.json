							"script": {
								"exec": [
									"var template = `",
									"<canvas id=\"membershipPlansChart\" height=\"75\"></canvas>",
									"",
									"<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js\"></script> ",
									"",
									"<script>",
									"    var ctx = document.getElementById(\"membershipPlansChart\");",
									"",
									"    var membershipPlansChart = new Chart(ctx, {",
									"        type: \"bar\",",
									"        data: {",
									"            labels: [\"Package Type\", \"Name\", \"Duration Days\", \"Is Active\", \"Is EMI Available\"],",
									"            datasets: [{",
									"                data: [{{response.package_type}}, {{response.name}}, {{response.duration_days}}, {{response.is_active}}, {{response.is_emi_available}}],",
									"                ",
									"                // Change these colours to customize the chart",
									"                backgroundColor: [\"#003f5c\", \"#58508d\", \"#bc5090\", \"#ff6361\", \"#ffa600\"],",
									"            }]",
									"        },",
									"        options: {",
									"            legend: { display: false },",
									"            title: {",
									"                display: true,",
									"                text: 'Membership Plans Details'",
									"            },",
									"            scales: {",
									"                xAxes: [{",
									"                    display: true,",
									"                    scaleLabel: {",
									"                        display: true,",
									"                        labelString: 'Attributes'",
									"                    }",
									"                }],",
									"                yAxes: [{",
									"                    display: true,",
									"                    scaleLabel: {",
									"                        display: true,",
									"                        labelString: 'Values'",
									"                    }",
									"                }]",
									"            }",
									"        }",
									"",
									"    });",
									"",
									"    // Access the data passed to pm.visualizer.set() from the JavaScript",
									"    // code of the Visualizer template",
									"    pm.getData(function (err, value) {",
									"        membershipPlansChart.data.datasets[0].data = value.response;",
									"        membershipPlansChart.update();",
									"    });",
									"",
									"</script>`;",
									"",
									"function constructVisualizerPayload() {",
									"    var res = pm.response.json();",
									"",
									"    var visualizerData = {",
									"        package_type: res.package_type,",
									"        name: res.name,",
									"        duration_days: res.duration_days,",
									"        is_active: res.is_active,",
									"        is_emi_available: res.is_emi_available",
									"    };",
									"",
									"    return {response: visualizerData};",
									"}",
									"",
									"pm.visualizer.set(template, constructVisualizerPayload());"
								],
								"type": "text/javascript",
								"packages": {}
							}
